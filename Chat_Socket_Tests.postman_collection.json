{
  "info": {
    "name": "Chat Socket Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Chat (HTTP)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"participants\": [\"{{user_id}}\", \"{{other_user_id}}\"]}"
        },
        "url": {
          "raw": "{{base_url}}/chat",
          "host": ["{{base_url}}"],
          "path": ["chat"]
        }
      }
    },
    {
      "name": "2. Socket Connection",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "ws://{{base_url}}/socket.io/?EIO=4&transport=websocket",
          "protocol": "ws",
          "host": ["{{base_url}}"],
          "path": ["socket.io"],
          "query": [
            {
              "key": "EIO",
              "value": "4"
            },
            {
              "key": "transport",
              "value": "websocket"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Set authentication token in handshake auth",
              "pm.request.headers.add({",
              "    key: 'Authorization',",
              "    value: `Bearer ${pm.environment.get('jwt_token')}`",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Join Chat Room",
      "request": {
        "method": "websocket",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "2probe"
        }
      }
    },
    {
      "name": "4. Send Ping",
      "request": {
        "method": "websocket",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "3probe"
        }
      }
    },
    {
      "name": "5. Join Specific Chat",
      "request": {
        "method": "websocket",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "42[\"join_chats\",[\"{{chat_id}}\"]]"
        }
      }
    },
    {
      "name": "6. Send Message",
      "request": {
        "method": "websocket",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "42[\"send_message\",{\"chatId\":\"{{chat_id}}\",\"content\":\"Hello, this is a test message!\"}]"
        }
      }
    },
    {
      "name": "7. Start Typing",
      "request": {
        "method": "websocket",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "42[\"typing_start\",\"{{chat_id}}\"]"
        }
      }
    },
    {
      "name": "8. Stop Typing",
      "request": {
        "method": "websocket",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "42[\"typing_stop\",\"{{chat_id}}\"]"
        }
      }
    }
  ],
  "event": [],
  "variable": [
    {
      "key": "base_url",
      "value": "localhost:5000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "your-jwt-token",
      "type": "string"
    },
    {
      "key": "chat_id",
      "value": "your-chat-id",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "your-user-id",
      "type": "string"
    },
    {
      "key": "other_user_id",
      "value": "other-user-id",
      "type": "string"
    }
  ]
}
